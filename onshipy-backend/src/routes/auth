const bcrypt = require('bcryptjs');
const { v4: uuidv4 } = require('uuid');
const crypto = require('crypto');
const db = require('../db/knex');

module.exports = async function(fastify) {

  // POST /api/auth/register
  fastify.post('/register', async (req, reply) => {
    const { full_name, email, password, store_name } = req.body;

    if (!full_name || !email || !password || !store_name) {
      return reply.status(400).send({ error: 'All fields are required' });
    }

    if (password.length < 8) {
      return reply.status(400).send({ error: 'Password must be at least 8 characters' });
    }

    // Check if email already exists
    const existing = await db('sellers').where({ email }).first();
    if (existing) {
      return reply.status(409).send({ error: 'Email already registered' });
    }

    const password_hash = await bcrypt.hash(password, 12);
    const webhook_secret = crypto.randomBytes(32).toString('hex');

    const [seller] = await db('sellers').insert({
      full_name,
      email,
      password_hash,
      store_name,
      webhook_secret,
      plan: 'free'
    }).returning(['id', 'full_name', 'email', 'store_name', 'plan', 'webhook_secret']);

    const token = fastify.jwt.sign(
      { id: seller.id, email: seller.email },
      { expiresIn: '7d' }
    );

    return reply.status(201).send({
      message: 'Account created successfully',
      token,
      seller
    });
  });

  // POST /api/auth/login
  fastify.post('/login', async (req, reply) => {
    const { email, password } = req.body;

    if (!email || !password) {
      return reply.status(400).send({ error: 'Email and password required' });
    }

    const seller = await db('sellers').where({ email }).first();
    if (!seller) {
      return reply.status(401).send({ error: 'Invalid email or password' });
    }

    const valid = await bcrypt.compare(password, seller.password_hash);
    if (!valid) {
      return reply.status(401).send({ error: 'Invalid email or password' });
    }

    const token = fastify.jwt.sign(
      { id: seller.id, email: seller.email },
      { expiresIn: '7d' }
    );

    return reply.send({
      message: 'Login successful',
      token,
      seller: {
        id: seller.id,
        full_name: seller.full_name,
        email: seller.email,
        store_name: seller.store_name,
        plan: seller.plan
      }
    });
  });

};